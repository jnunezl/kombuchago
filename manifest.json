{
  "manifest_version": 2,
  "name": "Kombucha Go",
  "version": "1.0.0",
  "description": "Previene la suspensión del PC. Sin procesos externos. Compatible con Firefox y Chrome.",
  "browser_specific_settings": {
    "gecko": {
      "id": "kombuchago@extension",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "windows"
  ],
  "background": {
    "scripts": ["compat.js", "background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Kombucha Go",
    "default_icon": {
      "48": "icons/icon48.png",
      "96": "icons/icon96.png"
    }
  },
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  }
}
